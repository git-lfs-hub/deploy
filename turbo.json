// Cross-submodule CI test / build / deploy tasks.
{
  "$schema": "./node_modules/turbo/schema.json",
  "futureFlags": { "globalConfiguration": true },
  "global": {
    "ui": "tui",
    "inputs": ["*.js*", "*.mjs", "*.ts", "scripts/**", "!*.md", "!*.example"]
  },
  "tasks": {
    "//#config:root": {
      "env": ["GLH_ENV", "GLH_VARS_JSON"],
      "inputs": ["vars.input.json", ".config.json", "assets/**", "config/**"],
      "outputs": [
        "vars.json",
        "docs/vars.json",
        "docs/assets/**",
        "e2e/vars.json",
        "server/vars.json",
        "server/public",
        "admin/vars.json",
        "admin/public/favicon.png"
      ]
    },
    "config": {
      "dependsOn": ["//#config:root"],
      "inputs": ["wrangler.template.jsonc", "github-app.template.md"],
      "outputs": ["wrangler.jsonc", "github-app.md"]
    },
    "types": {
      "dependsOn": ["config"],
      "outputs": ["worker-configuration.d.ts"]
    },
    "check": {
      "dependsOn": ["types"]
    },
    "test": {
      "dependsOn": ["//#config:root"]
    },
    "@git-lfs-hub/server#test": {
      "dependsOn": ["@git-lfs-hub/docs#build", "types"],
      "inputs": ["$TURBO_DEFAULT$", "!public/**"]
    },
    "@git-lfs-hub/admin#test": {
      "dependsOn": ["types"],
      "inputs": ["$TURBO_DEFAULT$", "!public/**"]
    },
    "build": {
      "dependsOn": ["//#config:root"]
    },
    "@git-lfs-hub/docs#build": {
      "dependsOn": ["//#config:root"],
      "inputs": ["$TURBO_DEFAULT$", "vars.json"],
      "outputs": ["site/**"]
    },
    "@git-lfs-hub/server#build": {
      "dependsOn": ["@git-lfs-hub/docs#build", "types"],
      "inputs": ["$TURBO_DEFAULT$", "wrangler.jsonc", "!test/**"],
      "outputs": ["dist/**"]
    },
    "@git-lfs-hub/admin#build": {
      "dependsOn": ["types"],
      "inputs": ["$TURBO_DEFAULT$", "wrangler.jsonc", "!test/**"],
      "outputs": ["dist/**"]
    },
    "deploy": {
      "dependsOn": ["//#config:root"]
    },
    "@git-lfs-hub/server#deploy": {
      "dependsOn": ["@git-lfs-hub/docs#build", "types"],
      "env": ["CLOUDFLARE_API_TOKEN"],
      "passThroughEnv": ["WRANGLER_OUTPUT_FILE_PATH"],
      "cache": false
    },
    "@git-lfs-hub/admin#deploy": {
      "dependsOn": ["types"],
      "env": ["CLOUDFLARE_API_TOKEN"],
      "passThroughEnv": ["WRANGLER_OUTPUT_FILE_PATH"],
      "cache": false
    }
  }
}
