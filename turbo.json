{
  "$schema": "https://turborepo.dev/schema.json",
  "futureFlags": {
    "globalConfiguration": true
  },
  "global": {
    "ui": "tui",
    "inputs": ["*.js*", "*.mjs", "*.ts", "!*.md", "!*.example"]
  },
  "tasks": {
    "types": {},
    "test": {},
    "test:watch": { "cache": false, "persistent": true },
    "dev": { "cache": false, "persistent": true },
    "build": {},
    "deploy": {},
    "//#sync:docs": {
      "inputs": ["assets/**"],
      "outputs": ["docs/vars.json", "docs/assets/**"]
    },
    "@git-lfs-hub/docs#build": {
      "dependsOn": ["//#sync:docs"],
      "outputs": ["site/**"]
    },
    "//#sync:server": {
      "dependsOn": ["@git-lfs-hub/docs#build"],
      "inputs": ["docs/site/**"],
      "outputs": [
        "server/wrangler.jsonc",
        "server/worker-configuration.d.ts",
        "server/public/**"
      ]
    },
    "@git-lfs-hub/server#test": {
      "dependsOn": ["//#sync:server"],
      "inputs": ["$TURBO_DEFAULT$", "!docs/**", "!public/**"]
    },
    "@git-lfs-hub/server#test:watch": { "dependsOn": ["//#sync:server"] },
    "@git-lfs-hub/server#build": {
      "dependsOn": ["//#sync:server"],
      "inputs": ["$TURBO_DEFAULT$", "!docs/**", "!test/**"],
      "outputs": ["dist/**"]
    },
    "@git-lfs-hub/server#deploy": {
      "dependsOn": ["//#sync:server"],
      "env": ["CLOUDFLARE_API_TOKEN"],
      "cache": false
    }
  }
}
