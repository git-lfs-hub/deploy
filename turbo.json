{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "types": {},
    "test": {},
    "test:watch": { "cache": false, "persistent": true },
    "dev": { "cache": false, "persistent": true },
    "build": {},
    "deploy": {},
    "@git-lfs-hub/docs#build": {
      "outputs": ["site/**"]
    },
    "//#link": {
      "dependsOn": ["@git-lfs-hub/docs#build"],
      "inputs": ["docs/site/**", "justfile"],
      "outputs": ["server/public/**"]
    },
    "@git-lfs-hub/server#test": { "dependsOn": ["//#link"] },
    "@git-lfs-hub/server#test:watch": { "dependsOn": ["//#link"] },
    "@git-lfs-hub/server#build": {
      "dependsOn": ["//#link"],
      "outputs": ["dist/**"]
    },
    "@git-lfs-hub/server#deploy": { "dependsOn": ["//#link"], "cache": false }
  }
}
