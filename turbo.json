{
  "$schema": "./node_modules/turbo/schema.json",
  "futureFlags": {
    "globalConfiguration": true
  },
  "global": {
    "ui": "tui",
    "inputs": ["*.js*", "*.mjs", "*.ts", "scripts/**", "!*.md", "!*.example"]
  },
  "tasks": {
    "test": { "dependsOn": ["types"] },
    "test:watch": { "cache": false, "persistent": true },
    "dev": { "cache": false, "persistent": true },
    "build": { "dependsOn": ["types"] },
    "deploy": { "dependsOn": ["types"] },
    "//#config": {
      "env": ["GLH_ENV", "GLH_VARS_JSON"],
      "inputs": ["vars.input.json", ".config.json", "assets/**", "config/**"],
      "outputs": [
        "vars.json",
        "docs/vars.json",
        "docs/assets/**",
        "e2e/vars.json",
        "server/vars.json",
        "server/public"
      ]
    },
    "config": {
      "dependsOn": ["//#config"],
      "inputs": ["wrangler.template.jsonc", "github-app.template.md"],
      "outputs": ["wrangler.jsonc", "github-app.md"]
    },
    "types": {
      "dependsOn": ["config"],
      "outputs": ["worker-configuration.d.ts"]
    },
    "@git-lfs-hub/docs#build": {
      "inputs": ["$TURBO_DEFAULT$", "vars.json"],
      "outputs": ["site/**"]
    },
    "@git-lfs-hub/server#test": {
      "dependsOn": ["@git-lfs-hub/docs#build", "types"],
      "inputs": ["$TURBO_DEFAULT$", "!public/**"]
    },
    "@git-lfs-hub/server#test:watch": {
      "dependsOn": ["@git-lfs-hub/docs#build", "types"]
    },
    "@git-lfs-hub/server#build": {
      "dependsOn": ["@git-lfs-hub/docs#build", "types"],
      "inputs": ["$TURBO_DEFAULT$", "wrangler.jsonc", "!test/**"],
      "outputs": ["dist/**"]
    },
    "@git-lfs-hub/server#deploy": {
      "dependsOn": ["@git-lfs-hub/docs#build"],
      "env": ["CLOUDFLARE_API_TOKEN"],
      "cache": false
    }
  }
}
