{
  "name": "@git-lfs-hub/deploy",
  "private": true,
  "packageManager": "bun@1.3.13",
  "scripts": {
    "lint": "bunx oxlint .",
    "lint:fix": "bunx oxlint --fix .",
    "format": "bunx oxfmt",
    "format:check": "bunx oxfmt --check",
    "check": "turbo run check",
    "types": "turbo run types",
    "config:root": "config/cli.sh",
    "config": "turbo run config",
    "test": "turbo run test",
    "test:watch": "turbo run test-watch",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "deploy": "turbo run deploy"
  },
  "workspaces": [
    "config",
    "docs",
    "e2e",
    "lib",
    "server"
  ],
  "devDependencies": {
    "turbo": "^2.9.14"
  }
}
