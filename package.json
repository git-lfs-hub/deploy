{
  "name": "@git-lfs-hub/deploy",
  "private": true,
  "packageManager": "bun@1.3.13",
  "scripts": {
    "types": "turbo types",
    "config": "config/cli.sh",
    "test": "turbo test",
    "test:watch": "turbo test-watch",
    "dev": "config/cli.sh && cd admin && bun run dev",
    "dev:server": "config/cli.sh && cd server && bun run dev",
    "dev:docs": "config/cli.sh && cd docs && bun run dev",
    "build": "turbo build",
    "deploy": "turbo deploy"
  },
  "workspaces": [
    "admin",
    "config",
    "docs",
    "e2e",
    "lib",
    "server"
  ],
  "devDependencies": {
    "turbo": "^2.9.14"
  }
}
